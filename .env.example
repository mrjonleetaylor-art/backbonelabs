# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ElevenLabs
ELEVENLABS_WEBHOOK_SECRET=
ELEVENLABS_TOOL_SECRET=       # Bearer token validated by /api/square/order-status and /api/calendar/*

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Square (sandbox: SQUARE_ENVIRONMENT=sandbox, production: SQUARE_ENVIRONMENT=production)
SQUARE_ENVIRONMENT=sandbox
SQUARE_API_VERSION=           # e.g. 2025-01-23 — pin deliberately, never auto-track

# Resend
RESEND_API_KEY=

# Google Calendar OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_BASE_URL=         # e.g. https://www.relaydesk.com.au

# Internal
TOM_AGENT_ID=
JON_MOBILE=
JON_EMAIL=
